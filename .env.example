# IBKR Trader Engine — Environment Configuration
#
# Copy this file to .env and fill in your credentials.
# IMPORTANT: Never commit .env to git (it's in .gitignore)
#
# See README.md for detailed setup instructions.

# ==================================================================================
# TELEGRAM NOTIFICATIONS (Required for alerts)
# ==================================================================================

# Your personal Telegram bot token
# How to get it: Open Telegram, search @BotFather, /newbot, copy the token
# Example: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=your_personal_telegram_bot_token_here

# Shared Telegram group chat ID
# All friends post to the SAME group using their own bot tokens
# How to get it: Add bot to group, make it admin, extract from group info
# Example: -1001234567890 (note: -100 prefix for groups)
# This value is SHARED among all friends
TELEGRAM_SIGNALS_CHAT_ID=your_shared_group_chat_id_here

# ==================================================================================
# SUPABASE (Optional - for cloud data backup and analytics)
# ==================================================================================

# Uncomment these if you want to enable cloud sync
# See README.md for Supabase setup instructions

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SECRET_KEY=your-secret-key-here

# ==================================================================================
# MULTI-FRIEND SETUP
# ==================================================================================
#
# When sharing this project with friends:
#
# 1. Each friend creates their OWN Telegram bot via @BotFather
#    - Friend 1: token_1
#    - Friend 2: token_2
#    - You: token_you
#
# 2. All bots are added to the SAME Telegram group
#    - Group: "SPX Trading Signals" (or your chosen name)
#
# 3. Each friend fills in:
#    - TELEGRAM_BOT_TOKEN = their unique bot token
#    - TELEGRAM_SIGNALS_CHAT_ID = the shared group chat ID (same for all)
#
# Result: All friends' trading alerts appear in one group, with each bot
# visually distinct by name/avatar.
#
# Example .env for Friend 1:
#   TELEGRAM_BOT_TOKEN=987654:XYZ-ABC9876qrSt-uvw12P3k4l567mn22
#   TELEGRAM_SIGNALS_CHAT_ID=-1001234567890  # shared
#
# Example .env for You:
#   TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
#   TELEGRAM_SIGNALS_CHAT_ID=-1001234567890  # same shared ID
#
# ==================================================================================
